{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tendergraph.local/contracts/impact-candidate.schema.json",
  "title": "TenderGraph Shadow Impact Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["items", "unchangedClaimIds", "gaps"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "action",
          "evidenceIds",
          "confidence",
          "rationale",
          "proposedStatement"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": ["corroborate", "invalidate", "supersede", "review"]
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "proposedStatement": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 2000
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "unchangedClaimIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
